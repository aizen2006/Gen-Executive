{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": false
  },
  "include": ["src/**/*.ts", "genie/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
