{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "outDir": "dist-server",
    "rootDir": ".",
    "noEmit": false
  },
  "include": ["server/**/*.ts", "genie/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-server"]
}
